# Server config — required env vars throw on startup if unset.
# Copy to .env and fill in v5 deployment values.

PORT=3001

# Supabase (recommended — server runs in-memory if blank, but the
# orphan-wager sweeper and character pin survive restarts only with
# Supabase configured. See STATUS_v5.md → "Block B — Supabase setup
# walkthrough" for free-tier provisioning steps.
#
# After filling these in, run `node setup-db.mjs` to print the schema
# SQL, then paste it into the Supabase SQL Editor.
SUPABASE_URL=
SUPABASE_KEY=

# Network: testnet | mainnet
SUI_NETWORK=testnet

# v5 — single fresh-publish package (no upgrade dichotomy).
# Captured from `sui client publish` output.
SUI_PACKAGE_ID=

# AdminCap object id, transferred to the treasury wallet at init.
ADMIN_CAP_ID=

# TransferPolicy<Item> + cap, created by marketplace::setup_transfer_policy.
# TRANSFER_POLICY_ID is read by clients to pay royalty on buy.
TRANSFER_POLICY_ID=
TRANSFER_POLICY_CAP_ID=

# Treasury wallet — receives wager fees + listing fees. Hardcoded in arena.move,
# so must match the publisher wallet on a fresh publish.
PLATFORM_TREASURY=

# Treasury wallet's Ed25519 private key, suiprivkey1... format.
# Required for the server to sign settle_wager / update_after_fight / set_fight_lock.
# NEVER commit this. Use a vault in production.
SUI_TREASURY_PRIVATE_KEY=
