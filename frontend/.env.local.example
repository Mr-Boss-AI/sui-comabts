# Frontend config — required env vars throw at module load if unset.
# Copy to .env.local and fill in v5 deployment values.

NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SUI_NETWORK=testnet

# v5 — single fresh-publish package id.
NEXT_PUBLIC_SUI_PACKAGE_ID=

# Treasury wallet — receives marketplace listing fees + wager platform fees.
NEXT_PUBLIC_TREASURY_ADDRESS=

# TransferPolicy<Item> object id (created by setup_transfer_policy after publish).
# Required for Kiosk buy flow once marketplace UI lands in v5.1.
NEXT_PUBLIC_TRANSFER_POLICY_ID=

# =============================================================================
# Enoki zkLogin  (Phase A, 2026-05-17)
# =============================================================================
#
# Sign-up flow:
#   1. Create an Enoki application at https://portal.enoki.mystenlabs.com/
#   2. Copy the API key into NEXT_PUBLIC_ENOKI_API_KEY below.
#   3. Register each OAuth client with its provider (see the per-provider
#      sections), then add the resulting client IDs to the Enoki app so
#      Enoki orchestrates the JWT -> zkLogin proof flow on your behalf.
#
# When NEXT_PUBLIC_ENOKI_API_KEY is unset OR no provider client ID is
# set, the Enoki wallet entries are silently omitted from the dApp Kit
# connect modal. Browser-injected wallets + the default Slush web
# wallet remain usable. Dev mode works without zkLogin configured.

NEXT_PUBLIC_ENOKI_API_KEY=

# -----------------------------------------------------------------------------
# Google OAuth  (Sign in with Google)
# -----------------------------------------------------------------------------
# Setup:
#   1. https://console.cloud.google.com/  ->  Credentials  ->  Create OAuth
#      client ID  ->  Web application.
#   2. Authorized redirect URIs: register the EXACT path the frontend
#      sends. We pin redirectUrl to `<origin>/auth/callback` in
#      `frontend/src/config/dapp-kit.ts`, so add:
#        http://localhost:3000/auth/callback   (dev)
#        https://<your-domain>/auth/callback   (prod)
#      Both providers require exact-match on path + query — registering
#      bare `http://localhost:3000/` will fail with redirect_mismatch.
#   3. Copy the Client ID below.

NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Twitch OAuth  (Sign in with Twitch)
# -----------------------------------------------------------------------------
# Setup:
#   1. https://dev.twitch.tv/console  ->  Applications  ->  Register Your
#      Application.
#   2. OAuth Redirect URLs: register the same `<origin>/auth/callback`
#      path as Google (dev + prod). Twitch returns `error=redirect_mismatch`
#      with HTTP 200 + a redirect to one of the registered URIs when the
#      requested redirect_uri doesn't match — easy to miss because the
#      popup just closes.
#   3. Copy the Client ID below.

NEXT_PUBLIC_TWITCH_CLIENT_ID=

# -----------------------------------------------------------------------------
# Apple OAuth  (Sign in with Apple)  -- PENDING ENOKI SDK SUPPORT
# -----------------------------------------------------------------------------
# Enoki 1.0.8's AuthProvider union does NOT yet include 'apple'. The
# Apple block below is intentionally commented out so the env example
# remains a snapshot of currently-wireable providers.
#
# When the Enoki SDK adds Apple, also update frontend/src/config/enoki.ts
# (add the apple entry to `candidates`) and uncomment this block.
#
# Setup:
#   1. https://developer.apple.com/  ->  Sign in with Apple  ->  Services ID
#   2. Configure redirect URIs the same way as Google + Twitch.
#   3. Copy the Services ID below.
#
# NEXT_PUBLIC_APPLE_CLIENT_ID=
